# ===========================================
# REQUIRED — backend connection
# ===========================================
# Full URL to the FastAPI backend including the /api prefix.
# The api.js wrapper appends paths like /auth/login, /admin/users, etc.
VITE_API_BASE_URL=http://localhost:8000/api
# VITE_API_BASE_URL=http://0.0.0.0:8000/api


# ===========================================
# APP BRANDING (optional, currently not consumed by code but reserved)
# ===========================================
VITE_APP_NAME=Spotless Solutions
VITE_APP_ENV=development


# ===========================================
# PENDING FEATURES — leave blank until wired
# ===========================================

# Google OAuth client ID (for SSO login). Obtain from Google Cloud Console.
# Used by the "Continue with Google" button on /login.
VITE_GOOGLE_CLIENT_ID=

# Razorpay public key id for client-side checkout.
# Use rzp_test_xxx for development, rzp_live_xxx in production.
VITE_RAZORPAY_KEY_ID=

# CDN/S3 base URL for static assets (product images, etc.)
# Leave blank to load from backend's local /attachment paths.
VITE_ASSETS_BASE_URL=
