# Copy this file to `.env` before running `npm run dev`.
# Only variables prefixed with VITE_ are exposed to the client bundle.

# Backend API URL (include the /api prefix).
# If left blank, Vite dev server proxies /api -> http://localhost:8000.
VITE_API_BASE_URL=http://localhost:8000/api

# Branding
VITE_APP_NAME=Spotless Solutions
VITE_APP_ENV=development

# Pending integrations — leave blank until implemented
VITE_GOOGLE_CLIENT_ID=
VITE_RAZORPAY_KEY_ID=
VITE_ASSETS_BASE_URL=

# Feature flags
# Set to "true" once the backend exposes /api/admin/services endpoints.
VITE_FEATURE_ADMIN_SERVICES=false
